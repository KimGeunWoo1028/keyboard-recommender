# -----------------------------------------------------------------------------
# Keyboard Recommender — frontend (Next.js) template
# Copy to `frontend/.env.local`. Never commit `.env.local`.
#
# See: docs/env-configuration.md (repo root)
# -----------------------------------------------------------------------------

# Browser-visible API origin (must use NEXT_PUBLIC_*). Use https:// in production.
# Match host with the address bar (e.g. all `localhost` or all `127.0.0.1`).
NEXT_PUBLIC_API_URL=http://localhost:8010

# Optional dev proxy: same-origin /api/* to FastAPI (omit NEXT_PUBLIC_API_URL if you rely on proxy only).
# INTERNAL_API_PROXY_TARGET=http://localhost:8010

# Server-only: token for gated /debug pages (never use NEXT_PUBLIC_* for secrets).
# INTERNAL_DEBUG_TOKEN=

# Optional: expose /debug routes in the UI (flag only — no secrets).
# NEXT_PUBLIC_INTERNAL_DEBUG=1
