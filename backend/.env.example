# -----------------------------------------------------------------------------
# Keyboard Recommender — backend environment template
# Copy to `backend/.env` and fill in values. Never commit `backend/.env`.
#
# See: docs/env-configuration.md (repo root)
# -----------------------------------------------------------------------------

# --- Tier: local | development | staging | production ------------------------
APP_ENV=local

# PostgreSQL (use / before the database name, not Windows \)
DATABASE_URL=postgresql+psycopg://keyboard:keyboard@localhost:5432/keyboard_recommender

# Browser origins allowed to call the API (comma-separated, exact match).
# Local Next.js default:
CORS_ORIGINS=http://localhost:3000

# SPA URL (password-reset links, etc.) — same host you use in the address bar.
PUBLIC_FRONTEND_BASE_URL=http://localhost:3000

# HTTP local dev: browsers ignore Secure cookies without HTTPS.
AUTH_COOKIE_SECURE=false

# Optional cookie flags (see docs/production-https.md)
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Secrets (SMTP, Resend, internal debug) — production/staging only in real deploys
# -----------------------------------------------------------------------------
DEBUG=false

# Mail: smtp | resend
EMAIL_PROVIDER=smtp
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_HOST=
# SMTP_FROM_EMAIL=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# Internal HTTP debug API (never enable on public production without a token)
# INTERNAL_DEBUG_API_ENABLED=false
# INTERNAL_DEBUG_TOKEN=

# Feature flags (examples; defaults vary — see config/settings.py)
# ENABLE_EVALUATION_PERSISTENCE=false
# ENABLE_FEEDBACK_LEARNING_MVP=false
# Staging verify: docs/staging-feedback-learning-mvp.md
# python scripts/verify_feedback_learning_mvp.py --dry-run-local
# python scripts/verify_feedback_learning_mvp.py --base-url https://YOUR_STAGING_API
# Keep ENABLE_FEEDBACK_LEARNING_MVP=false in production until staging checklist passes.

# Ops webhooks (never commit real URLs — use CI secrets / local .env only)
# CATALOG_CHANGE_ALERT_WEBHOOK_URL=
# OPERATIONAL_ALERT_WEBHOOK_URL=
# Optional refreshed inventory CSV for live pipeline:
# SWAGKEY_PRODUCTS_CSV=

SCALING_PROFILE=medium

# Optional: session TTL
# AUTH_SESSION_TTL_MINUTES=60
